{
  "model": "opus[1m]",
  "effortLevel": "max",
  "enabledMcpjsonServers": ["nmiai"],
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-commit.sh",
            "timeout": 120,
            "statusMessage": "Running pre-commit checks..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/lint-after-edit.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/security-imports.sh",
            "timeout": 10,
            "statusMessage": "Checking for forbidden imports..."
          }
        ]
      }
    ]
  }
}
